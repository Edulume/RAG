# Edulume RAG Environment Variables

# ============================================
# API Keys (Required)
# ============================================

# Anthropic API - For question extraction (Claude Vision)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API - For embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-xxxxx

# ============================================
# Server Configuration
# ============================================

# API Server
API_HOST=0.0.0.0
API_PORT=6969

# Environment
NODE_ENV=development
PYTHON_ENV=development

# ============================================
# Database / Vector Store
# ============================================

# FAISS Index Paths
NCERT_INDEX_PATH=./indexes/ncert-content
QUESTIONS_INDEX_PATH=./indexes/questions

# ============================================
# Extraction Pipeline
# ============================================

# Claude Model for extraction
EXTRACTION_MODEL=claude-3-5-haiku-20241022

# Image processing
IMAGE_QUALITY=85
IMAGE_DPI=300

# Concurrency
MAX_CONCURRENT_REQUESTS=3
BATCH_SIZE=5

# ============================================
# Paths
# ============================================

# Data directories
NCERT_BOOKS_PATH=./data/ncert-books
QUESTION_BANK_PATH=./data/question-bank
QUESTION_CSV_PATH=./data/question-bank.csv

# ============================================
# Logging
# ============================================

LOG_LEVEL=INFO
LOG_FILE=./logs/rag.log
